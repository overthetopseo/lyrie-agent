# Lyrie Agent — Environment Configuration
# Copy this file to .env and fill in your API keys.
# Never commit .env to version control.
# lyrie-shield: ignore-file (this is a documentation template; real .env files are scanned normally)

# ─── AI Provider Keys ───────────────────────────────────────────────────────

# Anthropic (Claude Opus 4.6, Sonnet 4.6, Haiku 4.5)
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-5.4, o4-mini, Codex)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# Google (Gemini 3.1 Pro, Flash)
# Get key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# xAI (Grok 4.20, Grok 4.1 Fast)
# Get key: https://console.x.ai/
XAI_API_KEY=xai-...

# MiniMax (M2.7, M2.7 HighSpeed — cheapest bulk model at $0.08/MTok)
# Get key: https://www.minimaxi.com/
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# ─── Local Models ────────────────────────────────────────────────────────────

# Ollama base URL (local — default http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# ─── Channel Tokens ──────────────────────────────────────────────────────────

# Telegram Bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Discord Bot
DISCORD_BOT_TOKEN=

# Slack Bot
SLACK_BOT_TOKEN=

# ─── Lyrie Configuration ─────────────────────────────────────────────────────

# Agent mode: cloud | local | hybrid
LYRIE_MODE=hybrid

# Prefer local models when available (true/false)
LYRIE_PREFER_LOCAL=false

# Memory base path (defaults to ~/.lyrie/memory)
LYRIE_MEMORY_PATH=

# Log level: debug | info | warn | error
LYRIE_LOG_LEVEL=info

# Shield mode: passive | active | strict
# passive = log threats only
# active = block confirmed threats
# strict = block anything suspicious
LYRIE_SHIELD_MODE=active

# ─── Infrastructure ──────────────────────────────────────────────────────────

# Node environment
NODE_ENV=development
